# ========================================
# DATABASE CONFIGURATION (Example)
# ========================================
# Change these values for production!
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=postgres
POSTGRES_HOST=postgres_db
POSTGRES_PORT=5432

# ========================================
# PGADMIN CONFIGURATION
# ========================================
PGADMIN_DEFAULT_EMAIL=admin@yourcompany.com
PGADMIN_DEFAULT_PASSWORD=your_secure_pgadmin_password

# ========================================
# JWT & SECURITY KEYS
# ========================================
# Generate secure keys for production!
# Example: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_min_32_chars
JWT_SECRET_KEY=your_jwt_secret_key_here_min_32_chars
ALGORITHM=HS256
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_EXPIRE_MINUTES=60
INTERNAL_SERVICE_SECRET=change_this_internal_service_secret

# ========================================
# SERVICE URLS (Internal Docker Network)
# ========================================
AUTH_SERVICE_URL=http://auth_service:8001
USER_SERVICE_URL=http://user_service:8002
SERVICE_FADESOL_URL=http://service_fadesol_service:8003
PROJECT_SERVICE_URL=http://project_service:8004
TASK_SERVICE_URL=http://task_service:8005
MESSAGE_SERVICE_URL=http://message_service:8006
CLICKUP_SERVICE_URL=http://clickup_service:8007
DASHBOARD_SERVICE_URL=http://dashboard_service:8008

# ========================================
# CLICKUP API CONFIGURATION
# ========================================
CLICKUP_TOKEN=change_me
CLICKUP_API_BASE_URL=https://api.clickup.com/api/v2
CLICKUP_WORKSPACE_ID=change_me
CLICKUP_SPACE_ID=change_me
CLICKUP_FOLDER_ID=change_me
CLICKUP_LIST_ID=change_me


# ========================================
# DATABASE URLS PER SERVICE
# ========================================
# Format: postgresql://username:password@host:port/database
AUTH_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/auth_db
USER_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/user_db
SERVICE_FADESOL_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/service_fadesol_db
PROJECT_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/project_db
TASK_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/task_db
MESSAGE_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/message_db
CLICKUP_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/clickup_db
DASHBOARD_DATABASE_URL=postgresql://postgres:your_password@postgres_db:5432/dashboard_db

# ========================================
# FRONTEND
# ========================================
VITE_API_BASE_URL=http://localhost:8000

# ========================================
# ENVIRONMENT
# ========================================
ENV=production
DEBUG=false
